<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"/>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Exora"
            android:textSize="34sp"
            android:textStyle="bold"
            android:textColor="#151C27"
            android:layout_marginTop="12dp"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Extra Organization App for school activities, student engagement, and extracurricular management."
            android:textAlignment="center"
            android:textColor="#424754"
            android:layout_marginTop="8dp"/>

        <!-- Card Login -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Role Selector -->
                <LinearLayout
                    android:id="@+id/roleContainer"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/role_background"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:padding="6dp">

                    <!-- Student ACTIVE -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnStudent"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/role_selected"
                        android:backgroundTint="@null"
                        android:text="Student"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <!-- Teacher -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnTeacher"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:backgroundTint="@null"
                        android:text="Teacher"
                        android:textAllCaps="false"
                        android:textColor="#374151"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                    <!-- Admin -->
                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/btnAdmin"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:backgroundTint="@null"
                        android:text="Admin"
                        android:textAllCaps="false"
                        android:textColor="#374151"
                        android:textSize="18sp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- School Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="School Email"
                    android:layout_marginTop="15dp"/>

                <EditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="name@school.sch.id"
                    android:inputType="textEmailAddress"/>

                <!-- Password -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Password"
                    android:layout_marginTop="15dp"/>

                <EditText
                    android:id="@+id/etPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="••••••••"
                    android:inputType="textPassword"/>

                <!-- Forgot Password -->
                <TextView
                    android:id="@+id/tvForgot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forgot Password?"
                    android:textColor="#0058BE"
                    android:layout_gravity="end"
                    android:layout_marginTop="5dp"/>

                <!-- Login Button -->
                <Button
                    android:id="@+id/btnLogin"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Sign In"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#0058BE"
                    android:layout_marginTop="20dp"/>

                <!-- Divider -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="or continue with"
                    android:textColor="#727785"
                    android:layout_gravity="center"
                    android:layout_marginTop="15dp"/>

                <!-- Social Login -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="14dp">

                    <!-- Google -->
                    <LinearLayout
                        android:id="@+id/btnGoogle"
                        android:layout_width="140dp"
                        android:layout_height="52dp"
                        android:background="@drawable/social_button_bg"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/google"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Google"
                            android:textColor="#374151"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                    <!-- Microsoft -->
                    <LinearLayout
                        android:id="@+id/btnMicrosoft"
                        android:layout_width="140dp"
                        android:layout_height="52dp"
                        android:layout_marginStart="12dp"
                        android:background="@drawable/social_button_bg"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp">

                        <ImageView
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/microsoft"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="Microsoft"
                            android:textColor="#374151"
                            android:textSize="15sp"
                            android:textStyle="bold"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Register -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="New to Exora? Join Organization"
            android:textColor="#006C49"
            android:textStyle="bold"
            android:layout_marginTop="20dp"/>
    </LinearLayout>

</ScrollView>
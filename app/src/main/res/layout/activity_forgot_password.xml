<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- Logo -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginTop="20dp"
            android:src="@drawable/logo"
            android:scaleType="fitCenter"
            android:contentDescription="App Logo"/>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Forgot Password"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#151C27"
            android:layout_marginTop="12dp"/>

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Enter your registered school email to reset your password."
            android:textAlignment="center"
            android:textColor="#424754"
            android:layout_marginTop="8dp"/>

        <!-- Card Forgot Password -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="25dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- School Email -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="School Email" />

                <EditText
                    android:id="@+id/etEmailForgot"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="name@school.sch.id"
                    android:inputType="textEmailAddress"
                    android:autofillHints="emailAddress"/>

                <!-- Reset Button -->
                <Button
                    android:id="@+id/btnResetPassword"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:text="Send Reset Link"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#0058BE"
                    android:layout_marginTop="25dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Back to Login -->
        <TextView
            android:id="@+id/tvBackToLoginForgot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Remembered your password? Sign In"
            android:textColor="#0058BE"
            android:textStyle="bold"
            android:layout_marginTop="20dp"
            android:padding="10dp"/>
    </LinearLayout>

</ScrollView>